NEXT_PUBLIC_APP_URL=http://localhost:3000

# WorkOS AuthKit
WORKOS_CLIENT_ID=client_...
WORKOS_API_KEY=sk_test_...
WORKOS_COOKIE_PASSWORD=replace-with-32-plus-char-secret
NEXT_PUBLIC_WORKOS_REDIRECT_URI=http://localhost:3000/callback

# Instagram / Meta
META_VERIFY_TOKEN=replace-with-meta-verify-token
META_APP_SECRET=replace-with-meta-app-secret
META_PAGE_ACCESS_TOKEN=replace-with-page-access-token
META_GRAPH_API_VERSION=v22.0
META_GRAPH_BASE_URL=https://graph.facebook.com

# AI
OPENAI_API_KEY=replace-with-openai-key

# Local development
SKIP_META_SEND=true
